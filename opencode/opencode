#!/usr/bin/env bash
set -euo pipefail

# Wrapper script to run the opencode coding agent inside a hardened Docker container.
#
# Features:
#   - Multi-language targets: base, go, php8.4, php8.5 (--lang)
#   - Optional image rebuild before running (--build)
#   - Optional tinyproxy sidecar for restricted outbound network access (--proxy)
#     with a configurable allowed-domains allowlist (--allowed-domains)
#   - Isolated internal Docker network when proxy is active
#   - Hardened container: capabilities dropped, no-new-privileges, private IPC
#   - Mounts current working directory, ~/.config/opencode, ditai, skills, and
#     ~/.config/acli read-write; entrypoint and xdg-open shim mounted read-only
#   - Forwards common API keys and opencode env-vars from the host environment
#   - Any unrecognised arguments are forwarded verbatim to opencode (use '--' to avoid
#     flag conflicts)

readonly OPENCODE_IMAGE='opencode-yolo'
readonly OPENCODE_PROXY_IMAGE='opencode-proxy'
readonly LANGS=(base go php8.4 php8.5)

SCRIPT_HOME="$(dirname "$(realpath "$0")")"
readonly SCRIPT_HOME

function check_docker() {
    if ! command -v docker &>/dev/null; then
        echo "Error: docker is not installed or not in PATH" >&2
        exit 1
    fi
    if ! docker info &>/dev/null; then
        echo "Error: Docker daemon is not running" >&2
        exit 1
    fi
}

function script_usage() {
    cat << EOF
Usage:
    opencode [OPTIONS] [OPENCODE_ARGS...]
    opencode [OPTIONS] -- [OPENCODE_ARGS...]

Options:
    -h|--help                   Displays this help
    -b|--build                  Rebuild the Docker image before running
    -l|--lang <LANG>            Specify language target (default: base). Valid options: ${LANGS[*]}
    -p|--proxy                  Start the proxy sidecar (restricted network access)
    --allowed-domains <file>    Path to allowed-domains file
                                (default: ~/.agents/proxy_allowed_domains.txt)

Any unrecognised options and arguments are forwarded to the opencode agent.
Use '--' to pass flags to opencode that would otherwise conflict with this script.
EOF
}

function build_proxy_image() {
    echo "Building Docker image: ${OPENCODE_PROXY_IMAGE} ..." >&2
    docker buildx build \
        --file "${SCRIPT_HOME}/../proxy/Dockerfile" \
        --tag "${OPENCODE_PROXY_IMAGE}:latest" \
        "${SCRIPT_HOME}/../proxy" >&2
}

function build_image() {
    echo "Building Docker image: ${OPENCODE_IMAGE} ..." >&2
    for target in "${LANGS[@]}"; do
        echo "Building target stage: ${target} ..." >&2
        docker buildx build \
            --file "${SCRIPT_HOME}/Dockerfile" \
            --target "${target}" \
            --tag "${OPENCODE_IMAGE}:${target}" \
            "${SCRIPT_HOME}" >&2
    done

    build_proxy_image
}


function start_proxy() {
    local proxy_allowed_domains_file="$1"
    local network_name="$2"
    local proxy_container="$3"

    echo "Starting proxy sidecar container '${proxy_container}' on network '${network_name}'..." >&2
    # Isolated internal network: opencode container has no direct internet access.
    docker network create --internal "${network_name}" >/dev/null

    echo "Running proxy container '${proxy_container}'..." >&2
    # Proxy runs on the default bridge (internet access) and the internal network.
    docker run -d \
        --rm \
        --name "${proxy_container}" \
        --volume "${proxy_allowed_domains_file}:/etc/tinyproxy/allowed_domains.txt:ro" \
        "${OPENCODE_PROXY_IMAGE}:latest" >/dev/null

    echo "Connecting proxy container '${proxy_container}' to network '${network_name}'..." >&2
    # Connect proxy to the internal network so the opencode container can reach it.
    docker network connect "${network_name}" "${proxy_container}" >/dev/null

    # Wait for tinyproxy to be ready (HEALTHCHECK in Dockerfile drives this).
    local attempts=0 state
    until [[ "$(docker inspect --format '{{.State.Health.Status}}' "${proxy_container}" 2>/dev/null)" == "healthy" ]]; do
        attempts=$((attempts + 1))
        if [[ $attempts -ge 30 ]]; then
            echo "Error: proxy container failed to become healthy" >&2
            docker logs "${proxy_container}" >&2 2>/dev/null || true
            return 1
        fi
        state=$(docker inspect --format '{{.State.Status}}' "${proxy_container}" 2>/dev/null || echo "gone")
        if [[ "$state" != "running" ]]; then
            echo "Error: proxy container exited unexpectedly" >&2
            echo "--- proxy logs ---" >&2
            docker logs "${proxy_container}" >&2 2>/dev/null || true
            return 1
        fi
        sleep 1
    done

    # Return the proxy's IP on the internal network.
    docker inspect "${proxy_container}" \
        --format "{{(index .NetworkSettings.Networks \"${network_name}\").IPAddress}}"
}

function stop_proxy() {
    local network_name="$1"
    local proxy_container="$2"
    docker stop "${proxy_container}" >/dev/null 2>&1 || true
    docker network rm "${network_name}" >/dev/null 2>&1 || true
}

function parse_params() {
    local param
    while [[ $# -gt 0 ]]; do
        param="$1"
        shift
        case $param in
            -h | --help)
                script_usage
                exit 0
                ;;
            -b | --build)
                build=true
                ;;
            -l | --lang)
                lang="$1"
                shift
                ;;
            -p | --proxy)
                proxy_flag=true
                ;;
            --allowed-domains)
                proxy_allowed_domains_file="$1"
                shift
                ;;
            --)
                # Everything after -- is forwarded verbatim to opencode
                opencode_passthrough+=("$@")
                return
                ;;
            *)
                opencode_passthrough+=("${param}")
                ;;
        esac
    done
}


readonly URL_PIPE="/tmp/fake-browser.$$.log"

function clean_pipe() {
  echo "Removing named pipe ${URL_PIPE} ..."
  rm -rf "${URL_PIPE}"
}

function main() {
    check_docker

    build=false
    lang="base"
    proxy_flag=false
    proxy_allowed_domains_file=""
    opencode_passthrough=()

    parse_params "$@"

    if [[ "${build}" == true ]]; then
        build_image
    else
        if ! docker image inspect "${OPENCODE_IMAGE}:${lang}" &>/dev/null; then
            echo "Image '${OPENCODE_IMAGE}:${lang}' not found. Building it first..." >&2
            build_image
        fi
        if [[ "${proxy_flag}" == true ]] && ! docker image inspect "${OPENCODE_PROXY_IMAGE}:latest" &>/dev/null; then
            echo "Image '${OPENCODE_PROXY_IMAGE}' not found. Building it first..." >&2
            build_proxy_image
        fi
    fi

    if [[ ! " ${LANGS[*]} " =~ " ${lang} " ]]; then
        echo "Error: unknown lang '${lang}'. Valid: ${LANGS[*]}" >&2
        exit 1
    fi

    echo "Running opencode in Docker container '${OPENCODE_IMAGE}' with language target '${lang}'..." >&2

    # Optionally start proxy sidecar and isolated network.
    local network_name="opencode-net-$$"
    local proxy_container="opencode-proxy-$$"

    if [[ "${proxy_flag}" == true ]]; then
        if [[ -z "${proxy_allowed_domains_file}" ]]; then
            proxy_allowed_domains_file="${HOME}/.agents/proxy_allowed_domains.txt"
        fi
        if [[ ! -f "${proxy_allowed_domains_file}" ]]; then
            echo "Error: allowed-domains file not found: ${proxy_allowed_domains_file}" >&2
            exit 1
        fi
        trap "stop_proxy '${network_name}' '${proxy_container}'" clean_pipe EXIT
        echo "Starting proxy sidecar (allowed-domains: ${proxy_allowed_domains_file})..." >&2
        local proxy_ip
        proxy_ip=$(start_proxy "${proxy_allowed_domains_file}" "${network_name}" "${proxy_container}")
        echo "Proxy ready at ${proxy_ip}:8888" >&2
    else
        echo "Proxy disabled (--proxy): unrestricted network access." >&2
        trap clean_pipe EXIT
    fi

    clean_pipe

    touch "${URL_PIPE}"

    # tail -n 0: only follow lines written after this process starts (skip stale entries).
    # Pipe gives FIFO semantics on the host side; the file is only used to cross
    # the Docker VirtioFS boundary (VirtioFS does not support mounted FIFOs on macOS).
    # WSL reports Linux via uname, so check it before the generic Linux case.
    # Prefer wslview (wslu package); fall back to explorer.exe which is always available in WSL.
    if grep -qiE 'microsoft|wsl' /proc/version 2>/dev/null; then
        if command -v wslview &>/dev/null; then
            _open_cmd='wslview'
        else
            _open_cmd='explorer.exe'
        fi
    else
        case "$(uname -s)" in
            Darwin) _open_cmd='open' ;;
            Linux)  _open_cmd='xdg-open' ;;
            *)      echo "Warning: unsupported OS, defaulting to xdg-open" >&2; _open_cmd='xdg-open' ;;
        esac
    fi

    tail -n 0 -f "${URL_PIPE}" | while read -r URL; do
        [[ -z "${URL}" ]] && continue
        "${_open_cmd}" "${URL}"
    done &

    local current_user
    current_user="$(id -u):$(id -g)"

    local docker_flags=(
        '--rm'
        '--user' "${current_user}"
        '--interactive'
        '--tty'
        # Drop all Linux capabilities (NET_RAW, SYS_PTRACE, …) so a compromised
        # process cannot manipulate the network stack, trace other processes, or
        # perform privileged kernel operations.
        '--cap-drop=ALL'
        # Prevent any exec inside the container from gaining capabilities via
        # setuid/setgid binaries or file capability bits (e.g. sudo, ping).
        '--security-opt=no-new-privileges'
        # Disable access to the host's IPC namespace (shared memory, semaphores,
        # message queues) so the container cannot communicate with or interfere
        # with other containers or host processes via IPC primitives.
        '--ipc=none'
        '--mount' "type=bind,source=$(pwd),target=$(pwd)"
        '--volume' "${HOME}/.config/opencode:/home/opencodeuser/.config/opencode"
        '--volume' "${HOME}/.agents:/home/opencodeuser/.agents"
        '--volume' "${HOME}/.opencode:/home/opencodeuser/.opencode"
        '--volume' "${HOME}/.config/acli:/home/opencodeuser/.config/acli"
        '--volume' "${SCRIPT_HOME}/entrypoint.sh:/usr/local/bin/entrypoint.sh:ro"
        '--volume' "${URL_PIPE}:/tmp/fake-browser.log"
        '--workdir' "$(pwd)"
        '--env' "TERM=${TERM:-xterm-256color}"
        '--env' "COLORTERM=${COLORTERM:-truecolor}"
        # Disable auto-update inside the container; the image controls the version.
        '--env' "OPENCODE_DISABLE_AUTOUPDATE=true"
    )

    if [[ "$(pwd)" != "${HOME}/ditai" ]]; then
        docker_flags+=(
            '--volume' "${HOME}/ditai:${HOME}/ditai" # Used because config is symlinked from here to user's home.
        )
    fi

    if [[ "${proxy_flag}" == true ]]; then
        docker_flags+=(
            '--network' "${network_name}"
            '--env' "HTTP_PROXY=http://${proxy_ip}:8888"
            '--env' "HTTPS_PROXY=http://${proxy_ip}:8888"
            '--env' "http_proxy=http://${proxy_ip}:8888"
            '--env' "https_proxy=http://${proxy_ip}:8888"
            '--env' "NO_PROXY=localhost,127.0.0.1"
            '--env' "no_proxy=localhost,127.0.0.1"
        )
    else
        docker_flags+=(
            '--network' 'host'
        )
    fi

    # Forward opencode-related env vars and API keys if set on the host.
    # Config file (~/.config/opencode/config.json) takes priority over these if present.
    local opencode_env_vars=(
        OPENCODE_CONFIG
        OPENCODE_CONFIG_DIR
        VISUAL
        EDITOR
        ANTHROPIC_API_KEY
        OPENAI_API_KEY
        GEMINI_API_KEY
        OPENCODE_API_KEY
    )
    local var
    for var in "${opencode_env_vars[@]}"; do
        [[ -n "${!var:-}" ]] && docker_flags+=('--env' "${var}=${!var}")
    done

    docker run "${docker_flags[@]}" "${OPENCODE_IMAGE}:${lang}" \
        "${opencode_passthrough[@]+"${opencode_passthrough[@]}"}"
}

main "$@"
